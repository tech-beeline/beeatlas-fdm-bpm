  <bpmn:process id="daily_s3_cleanup" name="Ежедневная очистка S3" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_to_cleanup_task</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0nkr0ez">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>

    <bpmn:sequenceFlow id="Flow_to_cleanup_task" sourceRef="StartEvent_1" targetRef="s3CleanupTask" />

    <bpmn:serviceTask id="s3CleanupTask" name="Вызов метода очистки S3" camunda:delegateExpression="#{CleanS3Delegate}">
      <bpmn:incoming>Flow_to_cleanup_task</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_to_end" sourceRef="s3CleanupTask" targetRef="Event_14z7w34" />

    <bpmn:endEvent id="Event_14z7w34">
      <bpmn:incoming>Flow_to_end</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>

